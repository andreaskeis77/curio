# Auto-detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Explicit text formats
*.md     text eol=lf
*.py     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf

# Windows-spezifische Skripte mit CRLF
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binäre Formate
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.zip    binary
*.tar.gz binary
*.sqlite binary
*.db     binary
