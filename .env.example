# Curiosity Wiki — Beispiel-Umgebungsvariablen
# Diese Datei dient als Vorlage. Eigene Geheimnisse gehören in .env (gitignored).

# -- LLM Provider (im MVP optional, T0.1 nutzt Mock-Modus) --
# Nur einer dieser Keys ist nötig, je nach gewähltem Provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -- Modellauswahl --
CURIOSITY_LLM_PROVIDER=mock
# mock | anthropic | openai
CURIOSITY_LLM_MODEL=
CURIOSITY_LLM_TEMPERATURE=0
CURIOSITY_LLM_TIMEOUT_SECONDS=60

# -- Pfade --
# Kann überschrieben werden, sonst Default = Repo-Root
CURIOSITY_VAULT_ROOT=

# -- Logging --
CURIOSITY_LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR
CURIOSITY_LOG_FORMAT=text
# text | json

# -- Web UI (später, ab M5) --
CURIOSITY_WEB_HOST=127.0.0.1
CURIOSITY_WEB_PORT=8765
CURIOSITY_WEB_AUTH_TOKEN=

# -- Dev Toggles --
CURIOSITY_DEV_FAIL_FAST=true
CURIOSITY_AGENT_DRY_RUN=true
